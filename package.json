{
  "name": "spindeck",
  "version": "0.1.0",
  "description": "Cross-platform vinyl visualization player that syncs & controls third-party music apps with playlist import support",
  "author": "Cherry Fu <https://github.com/dongguacute>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongguacute/SpinDeck.git"
  },
  "homepage": "https://github.com/dongguacute/SpinDeck#readme",
  "bugs": {
    "url": "https://github.com/dongguacute/SpinDeck/issues"
  },
  "keywords": [
    "vinyl",
    "music-player",
    "visualization",
    "react",
    "threejs",
    "gsap",
    "cross-platform"
  ],
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @spindeck/desktop build",
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @spindeck/desktop dev",
    "desktop:icons": "pnpm --filter @spindeck/desktop generate:icons",
    "desktop:prepare": "pnpm --filter @spindeck/desktop prepare:resources",
    "dev:docs": "vitepress dev docs",
    "build:docs": "vitepress build docs",
    "preview:docs": "vitepress preview docs",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.18.0",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
