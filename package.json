{
  "name": "spindeck",
  "version": "0.1.0",
  "description": "Cross-platform vinyl visualization player that syncs & controls third-party music apps with playlist import support",
  "author": "Cherry Fu <https://github.com/dongguacute>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongguacute/SpinDeck.git"
  },
  "homepage": "https://github.com/dongguacute/SpinDeck#readme",
  "bugs": {
    "url": "https://github.com/dongguacute/SpinDeck/issues"
  },
  "keywords": [
    "vinyl",
    "music-player",
    "visualization",
    "react",
    "threejs",
    "gsap",
    "cross-platform"
  ],
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "jiti": "^2.7.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
